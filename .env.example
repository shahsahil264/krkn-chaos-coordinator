# JIRA
JIRA_URL=https://redhat.atlassian.net
JIRA_USERNAME=your-email@redhat.com
JIRA_API_TOKEN=your-jira-api-token

# GitHub
GITHUB_TOKEN=your-github-pat

# Neo4j (for Graphiti)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LLM Backend (for FILTER phase — optional, falls back to keyword filter)
# Provider: ollama | anthropic | openai | google | none
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5-coder:14b

# Ollama (default local LLM — auto-detected if running)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (Claude API — for standalone CLI/dashboard without Claude Code)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GOOGLE_API_KEY=...

# Target release
OCP_RELEASE=4.21
